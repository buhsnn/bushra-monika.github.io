<style>
:root {
  --bg: #07090f;
  --bg2: #0d1020;
  --surface: #12162a;
  --surface2: #1a1f38;
  --border: #252a45;
  --border2: #2e3557;
  --purple: #7c6af7;
  --purple-light: #a89cf8;
  --purple-dim: rgba(124,106,247,0.15);
  --blue: #4a9eff;
  --blue-dim: rgba(74,158,255,0.12);
  --pink: #c084fc;
  --text: #e2e5f1;
  --text-muted: #8892b0;
  --text-dim: #3d4566;
  --white: #f8faff;
}

* { margin: 0; padding: 0; box-sizing: border-box; }
html { scroll-behavior: smooth; }

body {
  background: var(--bg);
  color: var(--text);
  font-family: 'DM Sans', sans-serif;
  font-size: 15px;
  line-height: 1.7;
  overflow-x: hidden;
}

/* Ambient orbs */
.orb {
  position: fixed;
  border-radius: 50%;
  filter: blur(120px);
  opacity: 0.18;
  pointer-events: none;
  z-index: 0;
}
.orb-1 { width: 600px; height: 600px; background: var(--purple); top: -200px; right: -100px; }
.orb-2 { width: 500px; height: 500px; background: var(--blue); bottom: 100px; left: -200px; }
.orb-3 { width: 300px; height: 300px; background: var(--pink); top: 50%; left: 50%; }

/* Noise */
body::after {
  content: '';
  position: fixed; inset: 0;
  opacity: 0.022;
  background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
  pointer-events: none;
  z-index: 999;
}

/* ── NAV ── */
nav {
  position: fixed; top: 0; left: 0; right: 0; z-index: 100;
  display: flex; justify-content: space-between; align-items: center;
  padding: 20px 64px;
  background: rgba(7,9,15,0.7);
  backdrop-filter: blur(20px);
  border-bottom: 1px solid rgba(255,255,255,0.04);
}

.nav-logo {
  font-family: 'Playfair Display', serif;
  font-size: 20px;
  font-weight: 700;
  color: var(--white);
  letter-spacing: -0.5px;
}

.nav-logo em {
  font-style: normal;
  background: linear-gradient(135deg, var(--purple-light), var(--blue));
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
}

nav ul { list-style: none; display: flex; gap: 36px; }
nav ul a {
  color: var(--text-muted);
  text-decoration: none;
  font-size: 13px;
  font-weight: 500;
  letter-spacing: 0.02em;
  transition: color 0.2s;
}
nav ul a:hover { color: var(--purple-light); }

.nav-cta {
  padding: 8px 20px;
  background: var(--purple-dim);
  border: 1px solid rgba(124,106,247,0.35);
  color: var(--purple-light) !important;
  border-radius: 6px;
  font-size: 13px !important;
  transition: all 0.2s !important;
}
.nav-cta:hover { background: rgba(124,106,247,0.25) !important; color: white !important; }

/* ── HERO ── */
#hero {
  min-height: 100vh;
  display: grid;
  grid-template-columns: 1fr 340px;
  align-items: center;
  gap: 80px;
  padding: 120px 64px 80px;
  position: relative;
  z-index: 1;
  max-width: 1300px;
  margin: 0 auto;
}

.hero-left { position: relative; }

.hero-status {
  display: inline-flex; align-items: center; gap: 8px;
  background: rgba(74,158,255,0.08);
  border: 1px solid rgba(74,158,255,0.25);
  color: var(--blue);
  padding: 7px 16px; border-radius: 100px;
  font-size: 12px; font-weight: 500; letter-spacing: 0.03em;
  margin-bottom: 28px;
  animation: fadeUp 0.5s ease both;
}
.hero-status::before {
  content: '';
  width: 7px; height: 7px;
  border-radius: 50%; background: var(--blue);
  animation: pulse 1.8s infinite;
}
@keyframes pulse { 0%,100%{opacity:1;transform:scale(1)} 50%{opacity:0.4;transform:scale(0.8)} }

.hero-title {
  font-family: 'Playfair Display', serif;
  font-size: clamp(44px, 6vw, 80px);
  font-weight: 900;
  line-height: 1.05;
  color: var(--white);
  letter-spacing: -2px;
  animation: fadeUp 0.5s ease 0.1s both;
}

.hero-title .grad {
  background: linear-gradient(135deg, var(--purple-light) 0%, var(--blue) 50%, var(--pink) 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
}

.hero-sub {
  margin-top: 20px;
  font-size: 16px;
  color: var(--text-muted);
  font-weight: 400;
  letter-spacing: 0.01em;
  animation: fadeUp 0.5s ease 0.15s both;
}

.hero-sub strong { color: var(--text); font-weight: 500; }

.hero-desc {
  margin-top: 28px;
  max-width: 520px;
  color: var(--text-muted);
  font-size: 14px;
  line-height: 1.85;
  animation: fadeUp 0.5s ease 0.2s both;
}

.hero-btns {
  margin-top: 40px;
  display: flex; gap: 14px; flex-wrap: wrap;
  animation: fadeUp 0.5s ease 0.25s both;
}

.btn {
  display: inline-flex; align-items: center; gap: 8px;
  padding: 13px 28px;
  font-family: 'DM Sans', sans-serif;
  font-size: 14px; font-weight: 500;
  text-decoration: none;
  border-radius: 8px;
  border: 1px solid;
  cursor: pointer;
  transition: all 0.25s;
}

.btn-primary {
  background: linear-gradient(135deg, var(--purple), #5b4fd4);
  border-color: var(--purple);
  color: white;
  box-shadow: 0 8px 32px rgba(124,106,247,0.3);
}
.btn-primary:hover {
  transform: translateY(-2px);
  box-shadow: 0 12px 40px rgba(124,106,247,0.45);
}

.btn-ghost {
  background: transparent;
  border-color: var(--border2);
  color: var(--text-muted);
}
.btn-ghost:hover {
  border-color: var(--purple);
  color: var(--purple-light);
  background: var(--purple-dim);
}

/* ── PHOTO ── */
.hero-photo-wrap {
  position: relative;
  animation: fadeUp 0.5s ease 0.3s both;
}

.hero-photo-frame {
  position: relative;
  width: 300px;
  height: 340px;
}

.hero-photo-frame::before {
  content: '';
  position: absolute;
  inset: -2px;
  background: linear-gradient(135deg, var(--purple), var(--blue), var(--pink));
  border-radius: 20px;
  z-index: 0;
}

.hero-photo-frame::after {
  content: '';
  position: absolute;
  inset: 3px;
  background: var(--bg2);
  border-radius: 18px;
  z-index: 1;
}

.hero-photo {
  position: absolute;
  inset: 3px;
  border-radius: 18px;
  object-fit: cover;
  object-position: center 8%;
  z-index: 2;
  width: calc(100% - 6px);
  height: calc(100% - 6px);
}

.photo-badge {
  position: absolute;
  bottom: -16px; left: -16px;
  background: var(--surface2);
  border: 1px solid var(--border2);
  border-radius: 12px;
  padding: 14px 20px;
  z-index: 10;
  backdrop-filter: blur(12px);
  box-shadow: 0 8px 32px rgba(0,0,0,0.4);
}

.photo-badge .badge-num {
  font-family: 'Playfair Display', serif;
  font-size: 28px;
  font-weight: 900;
  background: linear-gradient(135deg, var(--purple-light), var(--blue));
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  line-height: 1;
}

.photo-badge .badge-label {
  font-size: 11px;
  color: var(--text-muted);
  margin-top: 2px;
  font-weight: 500;
}

.photo-badge2 {
  position: absolute;
  top: 20px; right: -20px;
  background: linear-gradient(135deg, var(--purple), #5b4fd4);
  border-radius: 10px;
  padding: 10px 16px;
  z-index: 10;
  font-size: 12px;
  font-weight: 600;
  color: white;
  box-shadow: 0 8px 24px rgba(124,106,247,0.4);
}

/* ── SECTION COMMONS ── */
.section-wrap {
  padding: 100px 64px;
  max-width: 1300px;
  margin: 0 auto;
  position: relative;
  z-index: 1;
}

.section-label {
  display: flex; align-items: center; gap: 12px;
  margin-bottom: 56px;
}

.section-num {
  font-size: 11px; font-weight: 600;
  color: var(--purple-light);
  letter-spacing: 0.15em;
  text-transform: uppercase;
  background: var(--purple-dim);
  padding: 4px 10px;
  border-radius: 4px;
}

.section-title {
  font-family: 'Playfair Display', serif;
  font-size: 38px;
  font-weight: 900;
  color: var(--white);
  letter-spacing: -1px;
}

.section-line {
  flex: 1; height: 1px;
  background: linear-gradient(90deg, var(--border), transparent);
}

/* ── SKILLS ── */
.skills-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
  gap: 16px;
}

.skill-card {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: 12px;
  padding: 28px;
  transition: all 0.3s;
  position: relative;
  overflow: hidden;
}

.skill-card::before {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0; height: 2px;
  background: linear-gradient(90deg, var(--purple), var(--blue));
  opacity: 0;
  transition: opacity 0.3s;
}

.skill-card:hover { border-color: var(--border2); transform: translateY(-4px); box-shadow: 0 16px 48px rgba(0,0,0,0.3); }
.skill-card:hover::before { opacity: 1; }

.skill-icon { font-size: 28px; margin-bottom: 14px; }
.skill-cat { font-size: 12px; font-weight: 600; color: var(--purple-light); letter-spacing: 0.08em; text-transform: uppercase; margin-bottom: 14px; }

.tags { display: flex; flex-wrap: wrap; gap: 6px; }
.tag {
  font-size: 12px; padding: 4px 10px;
  background: var(--surface2); border: 1px solid var(--border);
  color: var(--text-muted); border-radius: 5px;
}

/* ── PROJECTS ── */
.projects-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 16px; }

.project-card {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: 14px;
  padding: 30px;
  text-decoration: none;
  color: inherit;
  transition: all 0.3s;
  display: flex;
  flex-direction: column;
  gap: 14px;
  position: relative;
  overflow: hidden;
}

.project-card::before {
  content: '';
  position: absolute; inset: 0;
  background: linear-gradient(135deg, var(--purple-dim), transparent);
  opacity: 0;
  transition: opacity 0.3s;
}

.project-card:hover { border-color: rgba(124,106,247,0.4); transform: translateY(-4px); box-shadow: 0 20px 60px rgba(0,0,0,0.35); }
.project-card:hover::before { opacity: 1; }

.project-header { display: flex; justify-content: space-between; align-items: flex-start; gap: 12px; }

.project-name {
  font-family: 'Playfair Display', serif;
  font-size: 19px; font-weight: 700;
  color: var(--white);
  line-height: 1.2;
}

.project-arrow {
  color: var(--text-dim);
  font-size: 18px;
  transition: all 0.2s;
  flex-shrink: 0;
  margin-top: 2px;
}
.project-card:hover .project-arrow { color: var(--purple-light); transform: translate(3px, -3px); }

.project-desc {
  color: var(--text-muted);
  font-size: 13px;
  line-height: 1.7;
  flex: 1;
}

.project-footer { display: flex; flex-wrap: wrap; gap: 6px; margin-top: auto; }
.ptag {
  font-size: 11px; padding: 3px 9px;
  background: var(--blue-dim);
  border: 1px solid rgba(74,158,255,0.2);
  color: var(--blue);
  border-radius: 4px;
}

/* ── EXPERIENCE ── */
.timeline { display: flex; flex-direction: column; gap: 0; position: relative; }
.timeline::before {
  content: '';
  position: absolute; left: 20px; top: 0; bottom: 0; width: 1px;
  background: linear-gradient(180deg, var(--purple), var(--blue), transparent);
}

.tl-item { display: grid; grid-template-columns: 60px 1fr; gap: 32px; padding-bottom: 60px; }

.tl-dot {
  display: flex; align-items: flex-start; justify-content: center;
  padding-top: 6px;
}

.tl-dot-inner {
  width: 12px; height: 12px;
  border-radius: 50%;
  background: linear-gradient(135deg, var(--purple), var(--blue));
  box-shadow: 0 0 0 4px rgba(124,106,247,0.15);
  flex-shrink: 0;
}

.tl-date { font-size: 12px; color: var(--purple-light); font-weight: 600; letter-spacing: 0.03em; margin-bottom: 6px; }
.tl-role { font-family: 'Playfair Display', serif; font-size: 22px; font-weight: 700; color: var(--white); margin-bottom: 4px; }
.tl-company { font-size: 13px; color: var(--text-muted); margin-bottom: 18px; }

.tl-bullets { list-style: none; display: flex; flex-direction: column; gap: 8px; }
.tl-bullets li { display: flex; gap: 10px; font-size: 13px; color: var(--text-muted); line-height: 1.6; align-items: flex-start; }
.tl-bullets li strong { display: inline; font-weight: 600; }
.tl-bullets li::before { content: '→'; color: var(--purple); flex-shrink: 0; font-size: 12px; margin-top: 2px; }

/* ── CONTACT ── */
#contact {
  position: relative; z-index: 1;
  text-align: center;
  padding: 100px 64px 140px;
}

.contact-tag {
  display: inline-block;
  font-size: 12px; font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase;
  color: var(--purple-light);
  background: var(--purple-dim);
  border: 1px solid rgba(124,106,247,0.25);
  padding: 6px 14px; border-radius: 100px;
  margin-bottom: 24px;
}

.contact-title {
  font-family: 'Playfair Display', serif;
  font-size: clamp(36px, 5vw, 64px);
  font-weight: 900;
  line-height: 1.1;
  color: var(--white);
  letter-spacing: -2px;
  margin-bottom: 20px;
}

.contact-title span {
  background: linear-gradient(135deg, var(--purple-light), var(--blue), var(--pink));
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
}

.contact-desc { color: var(--text-muted); font-size: 14px; max-width: 440px; margin: 0 auto 40px; line-height: 1.8; }

.contact-btns { display: flex; justify-content: center; gap: 14px; flex-wrap: wrap; }

/* ── FOOTER ── */
footer {
  border-top: 1px solid var(--border);
  padding: 24px 64px;
  display: flex; justify-content: space-between; align-items: center;
  color: var(--text-dim); font-size: 12px;
  position: relative; z-index: 1;
}

footer .grad-text {
  background: linear-gradient(135deg, var(--purple-light), var(--blue));
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  font-weight: 600;
}

@keyframes fadeUp { from{opacity:0;transform:translateY(20px)} to{opacity:1;transform:translateY(0)} }

@media (max-width: 900px) {
  #hero { grid-template-columns: 1fr; padding: 100px 24px 60px; gap: 48px; }
  .hero-photo-wrap { display: flex; justify-content: center; }
  .hero-photo-frame { width: 280px; height: 340px; }
  .section-wrap { padding: 70px 24px; }
  nav { padding: 16px 24px; }
  nav ul { display: none; }
  .projects-grid { grid-template-columns: 1fr; }
  footer { flex-direction: column; gap: 8px; text-align: center; padding: 20px 24px; }
  #contact { padding: 70px 24px 100px; }
}
</style>
</head>
